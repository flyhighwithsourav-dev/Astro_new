---
// C:\Users\SnowIce\Documents\antigravity\keen-hopper\src\pages\new-chart.astro
import Layout from '../layouts/Layout.astro';

// Offline major cities database
const PRESET_CITIES = [
  { name: "New Delhi, India", lat: 28.61, lng: 77.21 },
  { name: "Mumbai, India", lat: 19.07, lng: 72.87 },
  { name: "Bengaluru, India", lat: 12.97, lng: 77.59 },
  { name: "Kolkata, India", lat: 22.57, lng: 88.36 },
  { name: "Chennai, India", lat: 13.08, lng: 80.27 },
  { name: "New York, USA", lat: 40.71, lng: -74.00 },
  { name: "London, UK", lat: 51.50, lng: -0.12 },
  { name: "Tokyo, Japan", lat: 35.67, lng: 139.65 },
  { name: "Sydney, Australia", lat: -33.86, lng: 151.20 },
  { name: "Dubai, UAE", lat: 25.20, lng: 55.27 },
  { name: "Singapore", lat: 1.35, lng: 103.82 },
  { name: "San Francisco, USA", lat: 37.77, lng: -122.41 },
  { name: "Moscow, Russia", lat: 55.75, lng: 37.61 },
  { name: "Cape Town, South Africa", lat: -33.92, lng: 18.42 },
  { name: "Rio de Janeiro, Brazil", lat: -22.90, lng: -43.17 }
];
---

<Layout title="New Chart" activeTab="new_chart">
  <div class="new-chart-page animate-fade-in">
    <div class="card form-card">
      <h3 class="card-title">Cast New Horoscope</h3>
      
      <form id="chart-form" class="chart-form">
        <!-- Name -->
        <div class="form-group">
          <label class="form-label" for="name">Full Name</label>
          <input type="text" id="name" name="name" class="form-control" placeholder="e.g. John Doe" required />
        </div>
        
        <!-- Date of Birth -->
        <div class="form-group">
          <label class="form-label" for="dob">Date of Birth</label>
          <input type="date" id="dob" name="dob" class="form-control" required />
        </div>
        
        <!-- Time of Birth -->
        <div class="form-group">
          <label class="form-label" for="tob">Time of Birth</label>
          <input type="time" id="tob" name="tob" class="form-control" required />
        </div>
        
        <!-- Location preset -->
        <div class="form-group">
          <label class="form-label" for="city-preset">Birth Place (Select City)</label>
          <select id="city-preset" class="form-control">
            <option value="custom">-- Custom Coordinates --</option>
            {PRESET_CITIES.map(c => (
              <option value={`${c.lat},${c.lng}|${c.name}`}>{c.name}</option>
            ))}
          </select>
        </div>
        
        <!-- Coordinate fields -->
        <div class="coordinates-grid">
          <div class="form-group">
            <label class="form-label" for="latitude">Latitude (°)</label>
            <input type="number" step="0.0001" min="-90" max="90" id="latitude" name="latitude" class="form-control" placeholder="e.g. 28.61" required />
            <small class="help-text">North positive, South negative</small>
          </div>
          <div class="form-group">
            <label class="form-label" for="longitude">Longitude (°)</label>
            <input type="number" step="0.0001" min="-180" max="180" id="longitude" name="longitude" class="form-control" placeholder="e.g. 77.21" required />
            <small class="help-text">East positive, West negative</small>
          </div>
        </div>
        
        <div class="form-group">
          <label class="form-label" for="location-name">Location Name</label>
          <input type="text" id="location-name" name="locationName" class="form-control" placeholder="e.g. New Delhi, India" required />
        </div>
        
        <!-- Save profile checkbox -->
        <div class="form-group checkbox-group">
          <label class="checkbox-container">
            <input type="checkbox" id="save-profile" name="saveProfile" checked />
            <span class="checkmark"></span>
            Save to local profiles
          </label>
        </div>
        
        <!-- Submit Button -->
        <button type="submit" class="btn btn-primary btn-submit">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
          Cast Horoscope
        </button>
      </form>
    </div>
  </div>
</Layout>

<script>
  import { saveProfile } from '../lib/db';

  const form = document.getElementById('chart-form') as HTMLFormElement;
  const cityPreset = document.getElementById('city-preset') as HTMLSelectElement;
  const latInput = document.getElementById('latitude') as HTMLInputElement;
  const lngInput = document.getElementById('longitude') as HTMLInputElement;
  const locNameInput = document.getElementById('location-name') as HTMLInputElement;

  // Set default values for date and time inputs to today
  const today = new Date();
  const dobInput = document.getElementById('dob') as HTMLInputElement;
  const tobInput = document.getElementById('tob') as HTMLInputElement;
  if (dobInput) dobInput.value = today.toISOString().substring(0, 10);
  if (tobInput) tobInput.value = "12:00";

  // Pre-fill fields on city dropdown select
  if (cityPreset && latInput && lngInput && locNameInput) {
    cityPreset.addEventListener('change', () => {
      const val = cityPreset.value;
      if (val === 'custom') {
        latInput.value = '';
        lngInput.value = '';
        locNameInput.value = '';
        latInput.disabled = false;
        lngInput.disabled = false;
        locNameInput.disabled = false;
      } else {
        const [coords, name] = val.split('|');
        const [lat, lng] = coords.split(',');
        latInput.value = lat;
        lngInput.value = lng;
        locNameInput.value = name;
        
        // Auto-disable to indicate pre-fill, but they can switch to Custom to edit
        latInput.disabled = true;
        lngInput.disabled = true;
        locNameInput.disabled = true;
      }
    });
  }

  // Handle Form Submission
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Temporary enable so fields are collected in FormData
      if (latInput.disabled) {
        latInput.disabled = false;
        lngInput.disabled = false;
        locNameInput.disabled = false;
      }
      
      const formData = new FormData(form);
      const name = formData.get('name') as string;
      const dob = formData.get('dob') as string;
      const tob = formData.get('tob') as string;
      const lat = parseFloat(formData.get('latitude') as string);
      const lng = parseFloat(formData.get('longitude') as string);
      const loc = formData.get('locationName') as string;
      const shouldSave = formData.get('saveProfile') === 'on' || form.querySelector('#save-profile')?.getAttribute('checked') !== null;
      
      if (shouldSave) {
        const saved = saveProfile({
          name,
          birthDate: dob,
          birthTime: tob,
          latitude: lat,
          longitude: lng,
          locationName: loc
        });
        // Navigate using profile ID
        window.location.href = `/horoscope?id=${saved.id}`;
      } else {
        // Navigate using raw query params
        window.location.href = `/horoscope?name=${encodeURIComponent(name)}&dob=${dob}&tob=${tob}&lat=${lat}&lng=${lng}&loc=${encodeURIComponent(loc)}`;
      }
    });
  }
</script>

<style>
  .new-chart-page {
    padding: 16px;
    padding-bottom: 30px;
  }

  .form-card {
    max-width: 440px;
    margin: 0 auto;
  }

  .chart-form {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .coordinates-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .help-text {
    font-size: 0.72rem;
    color: var(--md-sys-color-on-surface-variant);
    margin-top: 4px;
    display: block;
    opacity: 0.8;
  }

  .btn-submit {
    margin-top: 16px;
    width: 100%;
    height: 48px;
  }

  /* Custom Checkbox Design */
  .checkbox-group {
    margin-top: 8px;
    margin-bottom: 12px;
  }

  .checkbox-container {
    display: block;
    position: relative;
    padding-left: 32px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 500;
    user-select: none;
    color: var(--md-sys-color-on-surface);
  }

  .checkbox-container input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    height: 0;
    width: 0;
  }

  .checkmark {
    position: absolute;
    top: 0;
    left: 0;
    height: 20px;
    width: 20px;
    background-color: var(--md-sys-color-surface-variant);
    border: 2px solid var(--md-sys-color-outline);
    border-radius: 6px;
    transition: all 0.2s ease;
  }

  .checkbox-container:hover input ~ .checkmark {
    border-color: var(--md-sys-color-primary);
    background-color: rgba(255, 217, 102, 0.05);
  }

  .checkbox-container input:checked ~ .checkmark {
    background-color: var(--md-sys-color-primary);
    border-color: var(--md-sys-color-primary);
  }

  .checkmark:after {
    content: "";
    position: absolute;
    display: none;
  }

  .checkbox-container input:checked ~ .checkmark:after {
    display: block;
  }

  .checkbox-container .checkmark:after {
    left: 6px;
    top: 2px;
    width: 5px;
    height: 10px;
    border: solid #241400;
    border-width: 0 2.5px 2.5px 0;
    transform: rotate(45deg);
  }
</style>
